# ========================================
# NextAuth.js 설정
# ========================================

# 랜덤 시크릿 키 (아래 명령어로 생성: openssl rand -base64 32)
NEXTAUTH_SECRET=여기에_랜덤_시크릿_키_입력

# 로컬 개발 시 URL
NEXTAUTH_URL=http://localhost:3000

# ========================================
# 데이터베이스 (SQLite - 기본값 유지)
# ========================================
DATABASE_URL="file:./dev.db"

# ========================================
# Google OAuth
# 설정 방법: https://console.cloud.google.com
# 1. 새 프로젝트 생성
# 2. OAuth 동의 화면 설정
# 3. 사용자 인증 정보 > OAuth 2.0 클라이언트 ID 생성
# 4. 승인된 리디렉션 URI: http://localhost:3000/api/auth/callback/google
# ========================================
GOOGLE_CLIENT_ID=여기에_Google_Client_ID
GOOGLE_CLIENT_SECRET=여기에_Google_Client_Secret

# ========================================
# Kakao OAuth
# 설정 방법: https://developers.kakao.com
# 1. 애플리케이션 추가
# 2. 앱 키 > REST API 키 복사
# 3. 카카오 로그인 활성화
# 4. Redirect URI: http://localhost:3000/api/auth/callback/kakao
# 5. 동의항목 > 닉네임, 프로필 사진, 카카오계정(이메일) 설정
# ========================================
KAKAO_CLIENT_ID=여기에_Kakao_REST_API_키
KAKAO_CLIENT_SECRET=여기에_Kakao_Client_Secret  # 없으면 빈칸

# ========================================
# Naver OAuth
# 설정 방법: https://developers.naver.com
# 1. 애플리케이션 등록
# 2. 사용 API: 네이버 로그인 선택
# 3. 서비스 URL: http://localhost:3000
# 4. Callback URL: http://localhost:3000/api/auth/callback/naver
# ========================================
NAVER_CLIENT_ID=여기에_Naver_Client_ID
NAVER_CLIENT_SECRET=여기에_Naver_Client_Secret
